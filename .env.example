# =========================================================
# 環境変数設定ファイル
# このファイルをコピーして .env を作成してください
# cp .env.example .env
# =========================================================

# OpenAI API Key（必須）
# https://platform.openai.com/api-keys で取得
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# データベース接続（Docker使用時はデフォルトのままでOK）
DATABASE_URL=postgresql://akiya:akiya_pass@db:5432/akiya_nav

# ローカル直接起動時はこちらを使用
# DATABASE_URL=postgresql://akiya:akiya_pass@localhost:5432/akiya_nav

# バックエンドURL（フロントエンドから参照）
BACKEND_URL=http://backend:8000

# ローカル直接起動時はこちらを使用
# BACKEND_URL=http://localhost:8000

# RAG設定
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4o
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K_RESULTS=5
